TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-token

ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
SESSION_SECRET=generate-with-openssl-rand-hex-32

PORT=3000
NODE_ENV=production

IMAP_HOST=imap.gmail.com
IMAP_USER=your-gmail-address@gmail.com
IMAP_PASSWORD=your-gmail-app-password

SMTP_HOST=smtp.gmail.com
SMTP_USER=your-gmail-address@gmail.com
SMTP_PORT=587
SMTP_PASSWORD=your-gmail-app-password

SITEWARE_API_TOKEN=your-siteware-api-token
SITEWARE_TRIAGE_AGENT_ID=your-triage-agent-id
SITEWARE_REPLY_AGENT_ID=your-reply-agent-id

ADMIN_EMAIL=your-gmail-address@gmail.com
DATA_RETENTION_DAYS=90
SESSION_DURATION_DAYS=7
